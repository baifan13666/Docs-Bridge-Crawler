{
  "crons": [
    {
      "path": "/api/crawler/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/crawler/cron/weekly",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/crawler/cron/monthly",
      "schedule": "0 4 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/api/crawler/worker",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ],
  "functions": {
    "app/api/crawler/worker/route.ts": {
      "maxDuration": 300
    },
    "app/api/embeddings/large/route.ts": {
      "maxDuration": 300
    }
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "NODE_ENV": "production"
    }
  },
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build"
}
