{
  "crons": [
    {
      "path": "/api/crawler/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/crawler/cron/weekly",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/crawler/cron/monthly",
      "schedule": "0 4 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/api/crawler/worker",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ]
}
