{
  "name": "docs-bridge-crawler",
  "version": "1.0.0",
  "description": "Government document crawler service for DocsBridge",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "verify-deployment": "node scripts/verify-deployment.js",
    "test-crawler": "node scripts/test-crawler.js",
    "postinstall": "node scripts/create-sharp-stub.js"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/qstash": "^2.3.0",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.0.0-rc.12",
    "next": "16.1.6",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "sharp": "file:./sharp-stub"
    }
  },
  "engines": {
    "node": "24.x"
  }
}
